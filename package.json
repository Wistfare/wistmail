{
  "name": "wistmail",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source email platform. Self-hostable email client + transactional email API.",
  "license": "MIT",
  "packageManager": "pnpm@10.6.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:e2e": "turbo test:e2e",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @wistmail/db generate",
    "db:migrate": "pnpm --filter @wistmail/db migrate",
    "db:seed": "pnpm --filter @wistmail/db seed",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.44.2"
    }
  }
}
