{
  "name": "@wistmail/ai-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "backfill": "tsx src/backfill.ts",
    "test": "vitest run",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@wistmail/ai": "workspace:*",
    "@wistmail/db": "workspace:*",
    "@wistmail/shared": "workspace:*",
    "bullmq": "^5.52.2",
    "drizzle-orm": "^0.44.2",
    "ioredis": "5.9.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  }
}
