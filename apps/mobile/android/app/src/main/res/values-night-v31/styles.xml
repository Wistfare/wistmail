<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31) dark-mode splash. Pairs with values-v31/styles.xml
  for the light variant — the night qualifier swaps the splash background
  to black; the splash_logo + wm_brand_text drawables also pick their
  drawable-night-* variants automatically (white logo, white wordmark).
-->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="android:windowSplashScreenBrandingImage">@drawable/wm_brand_text</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
