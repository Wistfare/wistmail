<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31) splash. The new SplashScreen API takes over from
  the legacy windowBackground path: without these attributes the system
  ignores launch_background.xml and shows the launcher icon (which has
  the white rounded-square adaptive background baked in — not what we
  want as a splash).

  windowSplashScreenAnimatedIcon points at @drawable/splash_icon — a
  variant of the brand mark with the art inset to ~50% of the canvas
  so the round W + satellites fit comfortably in the API's inner 192dp
  visible circle without clipping. (The legacy launch_background.xml
  keeps using @drawable/splash_logo which is full-canvas — that path
  has different sizing rules.) The night qualifier picks the white
  variant automatically.

  windowSplashScreenBrandingImage pins the "Wistfare Mail" wordmark
  at the bottom — same role as "from Meta" on WhatsApp's splash.
-->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="android:windowSplashScreenBrandingImage">@drawable/wm_brand_text</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
