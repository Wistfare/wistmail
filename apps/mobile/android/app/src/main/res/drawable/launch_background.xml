<?xml version="1.0" encoding="utf-8"?>
<!--
  Light-mode launch splash. Shown by Android while the app process
  starts. The corresponding dark variant lives at
  drawable-night/launch_background.xml — the system picks one based on
  the user's system theme.

  Density-specific PNGs live alongside this file in
  drawable-{mdpi,hdpi,xhdpi,xxhdpi,xxxhdpi}/splash_logo.png. The
  resource resolver walks the bucket list automatically; no per-density
  XML override is needed.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/white" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_logo" />
    </item>
</layer-list>
