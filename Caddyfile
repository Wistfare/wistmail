{
	# Disable Caddy's automatic HTTP→HTTPS redirects so we can
	# handle them ourselves and block direct IP access properly.
	auto_https disable_redirects
}

# HTTP — redirect the real domain to HTTPS, block everything else
:80 {
	@domain host {$SITE_DOMAIN:mail.wistfare.com}
	handle @domain {
		redir https://{$SITE_DOMAIN:mail.wistfare.com}{uri} permanent
	}
	respond "Not Found" 404
}

# HTTPS — serve the application
{$SITE_DOMAIN:mail.wistfare.com} {
	handle /api/* {
		reverse_proxy api:3001
	}

	handle {
		reverse_proxy web:3000
	}
}
