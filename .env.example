# =============================================================================
# WistMail Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://wistmail:wistmail@localhost:5432/wistmail

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO / S3 (Attachment Storage) ───────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=wistmail
S3_SECRET_KEY=wistmail-secret
S3_BUCKET=wistmail-attachments
S3_REGION=us-east-1

# ── MeiliSearch ───────────────────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=wistmail-search-key

# ── Mail Engine ───────────────────────────────────────────────────────────────
MAIL_DOMAIN=mail.example.com
SMTP_PORT=25
SMTP_SUBMISSION_PORT=587
IMAP_PORT=993

# ── API Gateway ───────────────────────────────────────────────────────────────
API_PORT=3001
API_URL=http://localhost:3001
JWT_SECRET=change-me-in-production

# ── Web Client ────────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Admin Dashboard ──────────────────────────────────────────────────────────
ADMIN_PORT=3002

# ── AI Configuration ─────────────────────────────────────────────────────────
# Provider: ollama | openai | anthropic
AI_PROVIDER=ollama
AI_FALLBACK_PROVIDER=

# Ollama (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── DNS Auto-Configuration ───────────────────────────────────────────────────
# Provider: cloudflare | manual
DNS_PROVIDER=manual
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── TLS / SSL ────────────────────────────────────────────────────────────────
TLS_CERT_PATH=
TLS_KEY_PATH=
ACME_EMAIL=
