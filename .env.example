# =============================================================================
# WistMail Environment Configuration
# Copy this file to .env and fill in / replace the dev values.
#
#   cp .env.example .env
#   docker compose up -d
#
# Every var below is consumed by docker-compose.yml or the apps it spins
# up. The required ones (marked "REQUIRED") have no safe defaults — the
# compose file refuses to start without them.
# =============================================================================

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=wistmail
# REQUIRED. Any string is fine for local dev; rotate before staging.
POSTGRES_PASSWORD=wistmail-dev-password
POSTGRES_DB=wistmail
DATABASE_URL=postgresql://wistmail:wistmail-dev-password@localhost:5432/wistmail

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO / S3 (Attachment Storage) ──────────────────────────────────────────
MINIO_ROOT_USER=wistmail
# REQUIRED. MinIO refuses to start without this.
MINIO_ROOT_PASSWORD=wistmail-dev-secret
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=wistmail
S3_SECRET_KEY=wistmail-dev-secret
S3_BUCKET=wistmail-attachments
S3_REGION=us-east-1

# ── MeiliSearch ──────────────────────────────────────────────────────────────
# REQUIRED. Min length 16 chars when MEILI_ENV=production.
MEILI_MASTER_KEY=wistmail-search-key-dev-only
MEILI_ENV=development
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=wistmail-search-key-dev-only

# ── Mail Engine ──────────────────────────────────────────────────────────────
# REQUIRED. The domain mail-engine answers SMTP / IMAP for. Use any
# resolvable hostname in dev — `mail.example.test` is fine.
MAIL_DOMAIN=mail.example.test
MAIL_HOSTNAME=mail.example.test
SMTP_PORT=25
SMTP_SUBMISSION_PORT=587
IMAP_PORT=993
# Override the host-side ports if 25/587/143/993 are already in use.
# SMTP_PORT_HOST=2525
# SMTP_SUBMISSION_PORT_HOST=2587
# IMAP_PORT_HOST=2143
# IMAP_SSL_PORT_HOST=2993
TLS_CERT_PATH=
TLS_KEY_PATH=

# ── Shared internal secret ───────────────────────────────────────────────────
# Used by mail-engine → api inbound calls AND by billing-cron →
# /billing/internal/tick. Must match across all services.
# REQUIRED. Generate with `openssl rand -hex 32`.
INBOUND_SECRET=dev-inbound-secret-change-me

# ── API Gateway ──────────────────────────────────────────────────────────────
API_PORT=3001
API_PORT_HOST=3001
API_URL=http://localhost:3001
API_INTERNAL_URL=http://api:3001
# REQUIRED. JWT signer for any token-mediated flows.
JWT_SECRET=dev-jwt-secret-change-me
# REQUIRED for the smoke flow — lets /setup/skip-dns advance past the
# DNS-verify step without a real nameserver. Leave false in production.
ALLOW_SKIP_DNS=true
SITE_URL=http://localhost:3000
NODE_ENV=production
# REQUIRED. AES-256-GCM key for MFA secrets at rest. 32-byte hex
# (64 chars). Generate with `openssl rand -hex 32`. Rotating this
# invalidates every stored TOTP secret — users must re-enroll.
MFA_SECRETS_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# ── Web Client ───────────────────────────────────────────────────────────────
WEB_PORT=3000
WEB_PORT_HOST=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Docs ─────────────────────────────────────────────────────────────────────
DOCS_PORT_HOST=3002

# ── Billing cron ─────────────────────────────────────────────────────────────
# How often the billing-cron container hits /billing/internal/tick.
# 5 minutes is plenty for trial → grace → suspended transitions.
BILLING_TICK_INTERVAL_MS=300000

# ── Wistfare Collections (billing) ───────────────────────────────────────────
# Leave WISTFARE_API_KEY blank in dev — the client returns stubbed
# responses so /billing/topup completes without dialing the provider.
WISTFARE_API_KEY=
WISTFARE_API_URL=
WISTFARE_BUSINESS_ID=biz_dev
WISTFARE_WALLET_ID=wal_dev
# Blank → webhook handler skips signature check, suitable for dev.
# Generate with `openssl rand -hex 32` for staging/prod.
WISTFARE_WEBHOOK_SECRET=

# ── Firebase Admin (push notifications) ──────────────────────────────────────
# Optional in dev. Drop the service account JSON at
# .secrets/firebase-service-account.json and set the project ID.
FIREBASE_PROJECT_ID=

# ── Caddy (only used under the `proxy` compose profile) ──────────────────────
SITE_DOMAIN=mail.wistfare.com
DOCS_DOMAIN=docs.mail.wistfare.com

# ── AI Configuration ─────────────────────────────────────────────────────────
# Provider: ollama | openai | anthropic
AI_PROVIDER=ollama
AI_FALLBACK_PROVIDER=

# Ollama (local) — bridge gateway for ai-worker → host. See compose
# file's ai-worker block for the rationale.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
AI_MODEL=gemma4:e4b

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── DNS Auto-Configuration ───────────────────────────────────────────────────
# Provider: cloudflare | manual
DNS_PROVIDER=manual
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── ACME / TLS ───────────────────────────────────────────────────────────────
ACME_EMAIL=
