                              "name": "cl1",
                              "fill": "#8BE9FD",
                              "content": "const validateToken = async (token: string) => {",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "CVyjz",
                              "name": "cl2",
                              "fill": "#F8F8F2",
                              "content": "  const decoded = jwt.verify(token, SECRET_KEY)",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "Pd1It",
                              "name": "cl3",
                              "fill": "#F8F8F2",
                              "content": "  if (!decoded.exp || decoded.exp < Date.now()) {",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "sTUhM",
                              "name": "cl4",
                              "fill": "#FF5555",
                              "content": "    throw new AuthError('Token expired')",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "BIJRc",
                              "name": "cl5",
                              "fill": "#F8F8F2",
                              "content": "  }",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "gYZsg",
                              "name": "cl6",
                              "fill": "#50FA7B",
                              "content": "  return decoded",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "aFm8u",
                              "name": "cl7",
                              "fill": "#F8F8F2",
                              "content": "}",
                              "fontFamily": "JetBrains Mono",
