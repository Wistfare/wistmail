              "children": [
                {
                  "type": "text",
                  "id": "bAQSC",
                  "name": "bodyP1",
                  "fill": "$wm-text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Hey team,",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "4C3Hz",
                  "name": "bodyP2",
                  "fill": "$wm-text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Sharing the updated roadmap for Q1. We've narrowed it down to three key priorities based on customer feedback and our strategic goals:",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "M2nwU",
                  "name": "bodyP3",
                  "fill": "$wm-text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "1. API v1 Launch — Full REST API with SDKs for TypeScript, Python, and Go. Target: end of January.\n\n2. Dashboard Redesign — New analytics dashboard with real-time delivery tracking. Target: mid-February.\n\n3. Mobile App — iOS and Android apps for inbox management. Target: end of March.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "qYzUE",
                  "name": "bodyP4",
                  "fill": "$wm-text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Please review and drop your feedback by Friday. Happy to jump on a call if needed.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "uo4Dy",
                  "name": "bodySign",
                  "fill": "$wm-text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Best,\nAlex",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        }
      ]
    },
