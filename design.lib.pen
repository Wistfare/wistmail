                      "type": "text",
                      "id": "GCT8v",
                      "name": "bodySign",
                      "fill": "$wm-text-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Best,\nAlex",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
