                  "type": "text",
                  "id": "Ylwd7",
                  "name": "edSign",
                  "fill": "$wm-text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Best,\nVedadom",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
