                    {
                      "type": "text",
                      "id": "eDawI",
                      "name": "bodyP2",
                      "fill": "$wm-text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Sharing the updated roadmap for Q1. We've narrowed it down to three key priorities based on customer feedback and our strategic goals:",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "3s3IU",
                      "name": "bodyP3",
                      "fill": "$wm-text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "1. API v1 Launch — Full REST API with SDKs for TypeScript, Python, and Go. Target: end of January.\n\n2. Dashboard Redesign — New analytics dashboard with real-time delivery tracking. Target: mid-February.\n\n3. Mobile App — iOS and Android apps for inbox management. Target: end of March.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
