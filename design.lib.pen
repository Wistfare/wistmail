                      "type": "text",
                      "id": "Y19um",
                      "name": "bodyP4",
                      "fill": "$wm-text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Please review and drop your feedback by Friday. Happy to jump on a call if needed.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
